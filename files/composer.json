{
    "name": "eiou/node",
    "description": "EIOU Node - Distributed IOU Network",
    "type": "project",
    "license": "Apache-2.0",
    "autoload": {
        "classmap": ["src/"],
        "files": [
            "src/database/Pdo.php",
            "src/database/DatabaseSetup.php",
            "src/database/DatabaseSchema.php",
            "src/services/ServiceWrappers.php",
            "src/schemas/OutputSchema.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Eiou\\Tests\\": "../tests/Unit/"
        }
    },
    "require": {
        "php": ">=8.1",
        "khanamiryan/qrcode-detector-decoder": "^2.0",
        "php-di/php-di": "^7.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit --configuration ../tests/phpunit.xml",
        "test-verbose": "phpunit --configuration ../tests/phpunit.xml --testdox",
        "test-debug": "phpunit --configuration ../tests/phpunit.xml --testdox --stop-on-failure",
        "test-coverage": "phpunit --configuration ../tests/phpunit.xml --coverage-text"
    }
}
