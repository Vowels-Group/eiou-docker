%% Best-Fee Cascade Timing Diagram
%% Shows how relay expiration cap ensures leaf-to-root ordering
%% within the originator's timeout window.
%%
%% Scenario: 60s originator expiration, hopWait=15s, 4 relay levels
%% Without cap: relays compute 75-285s, exceeding originator's 60s
%% With cap: each relay = upstream - hopWait, stays within window

gantt
    title Best-Fee Cascade Expiration Timeline (60s originator, hopWait=15s)
    dateFormat X
    axisFormat %ss

    section A6 (Relay 3 - Leaf)
    Active           :a6, 0, 15
    Expires → selects best candidate :milestone, m6, after a6, 0

    section A3 (Relay 2)
    Waiting for downstream :a3w, 0, 15
    Active (collecting candidates) :a3, 15, 30
    Expires → selects best candidate :milestone, m3, after a3, 0

    section A1 (Relay 1)
    Waiting for downstream :a1w, 0, 30
    Active (collecting candidates) :a1, 30, 45
    Expires → selects best candidate :milestone, m1, after a1, 0

    section A0 (Originator)
    Waiting for downstream :a0w, 0, 45
    Active (collecting candidates) :a0, 45, 60
    Expires → selects best route :milestone, m0, after a0, 0
