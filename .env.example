# =============================================================================
# EIOU Docker Node — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
# See docker-compose.yml for detailed descriptions of each variable.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d
# =============================================================================

# ---------------------------------------------------------------------------
# NODE IDENTITY
# ---------------------------------------------------------------------------

# Hostname for HTTP/HTTPS mode. Omit for Tor-only operation.
QUICKSTART=eiou

# Display name (cosmetic only, never broadcast)
# EIOU_NAME=My Node

# Externally reachable address (IP or domain) if different from QUICKSTART
# EIOU_HOST=192.168.1.100

# Non-standard port mapping
# EIOU_PORT=8443

# ---------------------------------------------------------------------------
# WALLET RESTORATION (choose one method, or omit for new wallet)
# ---------------------------------------------------------------------------

# Method 1 — File-based (RECOMMENDED, more secure)
# Requires seed file volume mount in docker-compose.yml
# RESTORE_FILE=/restore/seed

# Method 2 — Environment variable (less secure, visible in docker inspect)
# RESTORE=word1 word2 word3 ... word24

# ---------------------------------------------------------------------------
# SSL CERTIFICATE CONFIGURATION
# ---------------------------------------------------------------------------

# Override SSL certificate Common Name
# SSL_DOMAIN=node.example.com

# Additional Subject Alternative Names (comma-separated TYPE:value)
# SSL_EXTRA_SANS=DNS:alt.example.com,IP:10.0.0.1

# Let's Encrypt (requires real domain + port 80 reachable)
# LETSENCRYPT_EMAIL=admin@example.com
# LETSENCRYPT_DOMAIN=node.example.com
# LETSENCRYPT_STAGING=true

# P2P SSL verification (default: true)
# Set to false when all nodes use self-signed certificates
# P2P_SSL_VERIFY=true

# Custom CA certificate for P2P verification
# P2P_CA_CERT=/ssl-ca/ca.crt

# ---------------------------------------------------------------------------
# TIMEOUT CONFIGURATION
# ---------------------------------------------------------------------------
# Increase for WSL2 or slow/resource-constrained environments.

# Tor hidden service availability timeout (default: 60)
# EIOU_HS_TIMEOUT=60

# Tor network connectivity verification timeout (default: 120)
# EIOU_TOR_TIMEOUT=120

# ---------------------------------------------------------------------------
# FEATURE FLAGS
# ---------------------------------------------------------------------------

# Debug logging to database/GUI panel (default: false)
# APP_DEBUG=false

# Manual message processing + bypass rate limiting (default: false)
# EIOU_TEST_MODE=false

# Background contact online/offline status polling (default: true)
# EIOU_CONTACT_STATUS_ENABLED=true

# Automatic daily encrypted backups (default: true)
# EIOU_BACKUP_AUTO_ENABLED=true

# Auto-propose chain drops on mutual gap detection (default: true)
# EIOU_AUTO_CHAIN_DROP_PROPOSE=true

# Auto-accept chain drop proposals with balance guard (default: false)
# EIOU_AUTO_CHAIN_DROP_ACCEPT=false
