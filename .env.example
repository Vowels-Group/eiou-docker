# Application Configuration
APP_NAME=eIOU
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080

# Database Configuration
DB_CONNECTION=sqlite
DB_PATH=/var/www/html/data/database.sqlite
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=3600

# Security Settings
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60

# Logging Configuration
LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_MAX_FILES=30
LOG_PATH=/var/www/html/logs

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=eiou_cache
CACHE_TTL=3600

# Queue Configuration
QUEUE_CONNECTION=sync
QUEUE_FAILED_TABLE=failed_jobs

# Mail Configuration (Optional)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@eiou.example.com
MAIL_FROM_NAME="${APP_NAME}"

# Monitoring
MONITORING_ENABLED=true
METRICS_ENDPOINT=/metrics
HEALTH_CHECK_ENDPOINT=/health

# Performance
ENABLE_QUERY_LOG=false
ENABLE_CACHE=true
ENABLE_COMPRESSION=true
MAX_UPLOAD_SIZE=2M

# External Services (Optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SENTRY_DSN=

# Feature Flags
FEATURE_ADAPTIVE_POLLING=true
FEATURE_RATE_LIMITING=true
FEATURE_SECURITY_HEADERS=true
FEATURE_AUDIT_LOG=true

# Development (only for dev environment)
DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false